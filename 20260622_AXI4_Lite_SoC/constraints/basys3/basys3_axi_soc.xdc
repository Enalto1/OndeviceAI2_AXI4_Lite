# Basys3 constraints for MicroBlaze AXI4-Lite SoC
# Source top-level wrapper:
# vivado/basys3/microblaze_axi_soc/microblaze_axi_soc.gen/sources_1/bd/microblaze_axi_soc_bd/hdl/microblaze_axi_soc_bd_wrapper.v
# Vivado target: 2020.2, part xc7a35tcpg236-1

## Clock: Basys3 100 MHz oscillator
set_property PACKAGE_PIN W5 [get_ports {clk_100mhz_i}]
set_property IOSTANDARD LVCMOS33 [get_ports {clk_100mhz_i}]
create_clock -name clk_100mhz_i -period 10.000 [get_ports {clk_100mhz_i}]

## System reset v2: external PMOD JA4/G2 active-low reset with pull-up
## Vivado 2020.2 rejected the earlier CPU_RESETN/C12 assignment for part xc7a35tcpg236-1.
## Wiring model: JA4 signal -> push button -> GND, not pressed=1, pressed=0.
set_property PACKAGE_PIN G2 [get_ports {reset_i}]
set_property IOSTANDARD LVCMOS33 [get_ports {reset_i}]
set_property PULLUP true [get_ports {reset_i}]

## USB-UART bridge
set_property PACKAGE_PIN B18 [get_ports {uart_rxd_i}]
set_property IOSTANDARD LVCMOS33 [get_ports {uart_rxd_i}]
set_property PACKAGE_PIN A18 [get_ports {uart_txd_o}]
set_property IOSTANDARD LVCMOS33 [get_ports {uart_txd_o}]

