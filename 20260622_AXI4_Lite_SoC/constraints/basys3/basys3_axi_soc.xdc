set_property IOSTANDARD LVCMOS33 [get_ports {fnd_data_o[0]}]
set_property PACKAGE_PIN W6 [get_ports {fnd_data_o[1]}]
set_property IOSTANDARD LVCMOS33 [get_ports {fnd_data_o[1]}]
